APP_ENV=development
# Optional portable override. The default is %LOCALAPPDATA%\Application Viego on Windows.
# APPLICATION_VIEGO_DATA_DIR=C:\path\to\application-viego-data
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=
LLM_API_KEY_ENV_VAR=GEMINI_API_KEY
LLM_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=2048
LLM_BULLET_REWRITE_MAX_OUTPUT_TOKENS=8192
LLM_TIMEOUT_SECONDS=30
LLM_RETRY_COUNT=1
LLM_MAX_CALLS_PER_GENERATION=2
LLM_CACHE_TTL_SECONDS=900
LLM_ENABLE_ROLE_CLASSIFICATION=false
LLM_ROLE_CLASSIFICATION_MINIMUM_CONFIDENCE=0.7
LLM_ENABLE_OPPORTUNITY_ANALYSIS=false
LLM_ENABLE_COMPOSITION=false
LLM_ENABLE_BULLET_REWRITE=true
LLM_ENABLE_SHORTENING=false
LLM_DETERMINISTIC_FALLBACK=true
